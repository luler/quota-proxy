# 成功访问次数限制中间件配置

# 服务配置
server:
  port: 3000
  read_timeout: 10s          # 读取请求头的最大时间，防 slowloris 攻击
  idle_timeout: 120s         # keep-alive 空闲连接回收时间
  max_body_size: 104857600   # 请求/响应 body 最大字节数 (100MB)

# 上游服务配置
upstream:
  target: https://fastgpt.luler.top:443
  response_timeout: 120s     # 等待上游返回响应头的最大时间

# Redis 配置
redis:
  addr: redis:6379
  password: ""
  db: 0

# 访问主体识别配置
identity:
  # 策略：
  # - header_priority（默认）：按 extractors 顺序提取，命中第一个后作为 identity
  # - merge_all：遍历所有 extractors，把命中结果按 name:value 用 | 拼接成单一标识，
  #   例如 app_id:myapp|user_id:alice，可用于"多维联合"作为唯一分组键
  strategy: header_priority
  # 每条 extractor 描述一个取值来源，统一格式：
  #   source: header / query / cookie（必填，推荐显式填写）
  #   key:    参数名（header 名 / query 参数名 / cookie 名）
  #   regex + group: 可选，对取到的原始值再做一次 regex 抽取（group=0 表示整体）
  #                  所有 source 都支持 regex + group，不限于 header
  #   name:   最终 identity 中的字段名（如 name=user_id、值为 alice，则输出 user_id:alice）
  # 兼容写法：source=header 时，可用 header 字段代替 key（兼容旧配置，不推荐新配置使用）
  extractors:
    # 示例 1：从 Cookie 请求头里用 regex 抽取 member_id
    - source: header
      key: Cookie
      regex: '(^|;\s*)member_id=([^;]+)'
      group: 2
      name: member_id
    # 示例 2：直接取整条 header 值
    - source: header
      key: X-User-Id
      name: X-User-Id
    # 示例 3：从 URL query 参数取值
    # - source: query
    #   key: app_id
    #   name: app_id
    # 示例 4：从 cookie 直接取值（无需 regex）
    # - source: cookie
    #   key: member_id
    #   name: member_id
    # 示例 5：query 参数搭配 regex 抽取（如 token=prefix-abc123 只要 abc123 这段）
    # - source: query
    #   key: token
    #   regex: '^prefix-(.+)$'
    #   group: 1
    #   name: token
  # 当前面配置的 extractors 都未命中时，是否回退为客户端 IP（例如 ip:127.0.0.1）
  fallback_to_ip: true

# 配额配置
quota:
  enabled: true

  # 时间窗口按哪个时区计算
  # day 模式下，按这个时区的 00:00 切天
  # hour/minute 模式下，也按这个时区计算窗口边界
  timezone: Asia/Shanghai

  # 命中这些路径的请求不做配额检查，优先级高于下面的 rules
  exclude_paths:
    - /health
    - /metrics

  # Redis 异常时是否放行：
  # true  = 放行请求，但不计次
  # false = 直接返回错误
  fail_open: true

  # 按顺序匹配路径规则，命中第一个规则后即使用该规则的窗口和次数限制
  rules:
    # 聊天接口：按 1 天限制 2 次
    - name: chat-daily
      # 限流时间窗口：minute / hour / day
      window: day
      # 窗口数量，默认 1；minute/hour/day 都支持大于等于 1 的整数
      window_count: 1
      # 当前时间窗口内允许的最大成功次数
      success_limit: 2
      # 命中这些路径时使用本规则
      include_paths:
        - /api/core/chat/**
      # 可选：请求内容检测，默认不配置则不生效
      # 只有 include_paths 命中后，下面条件才会继续参与匹配
      request_match:
        # query + form 会被规范化为类似 a=1&b=2 的字符串，再做 regex 匹配
        # include 非空时要求至少命中一个；exclude 任一命中都会失败，可理解为 exclude 优先级更高
        query_form:
          include:
            - "(^|&)foo=bar(&|$)"
          exclude:
            - "(^|&)debug=true(&|$)"
        # JSON 请求体会被规范化为紧凑 JSON 文本，再做 regex 匹配
        # include/exclude 语义同上：即使 include 命中，只要命中 exclude 仍然失败
        json_body:
          include:
            - '"model":"coder-model-aiproxy"'
        # 请求头会被规范化为按行拼接的 name:value 文本，再做 regex 匹配
        # 适合精确匹配某一行 header，也支持用 exclude 排除特定头组合
        headers:
          include:
            - "(^|\\n)x-user-id:vip-user($|\\n)"
      # 可选：配额超限后的自定义返回内容；不配置则使用默认 JSON
      # 设置为普通文本时返回纯文本
      # 设置为空字符串时返回 429 且不返回任何内容
      # 若文本本身是合法 JSON，则按 JSON 返回
      quota_exceeded_body: 请求过于频繁，请稍后再试

    # 示例：空响应体
    - name: other-api-hourly
      window: hour
      window_count: 1
      success_limit: 20
      include_paths:
        - /api/other/**
      quota_exceeded_body: ""

# 成功判定规则
success_rule:
  # status_code: 仅按 HTTP 状态码判断是否成功
  # json_field: 先看 HTTP 状态码（若 require_http_2xx=true），再判断响应 JSON 字段是否等于 expected_value
  # SSE（text/event-stream）为流式特例：不读取完整 body，不使用 json_field；并且仍会先按 require_http_2xx 检查状态码，满足后在首个有效事件写出后计为成功
  mode: status_code  # status_code 或 json_field
  # 为 true 时，只有 HTTP 2xx 才可能判定为成功
  # 为 false 时，status_code 模式下 < 400 也算成功；json_field 模式下则不强制要求 2xx
  require_http_2xx: true
  # 仅在 mode=json_field 时生效，表示读取响应 JSON 中的哪个字段
  json_field: code
  # 仅在 mode=json_field 时生效，表示字段值等于多少时算成功
  expected_value: 0

# 日志配置
logging:
  level: info
  access_log: true

# 管理面板配置
admin:
  # 默认为空，表示未启用管理鉴权
  # 设置后，访问 /__admin/ui 以及其他 /__admin 接口需要提供对应的 API Key
  # 可通过 /__admin/ui?api_key=你的密钥 自动带入登录
  api_key: "admin"
